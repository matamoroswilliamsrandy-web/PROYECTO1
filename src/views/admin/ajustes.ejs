                    <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════ -->
                    <script>
                        // Tab switching
                        // Jump to a specific tab programmatically
                        function switchTab(tabId) {
                            const btn = document.querySelector(`[data-tab="${tabId}"]`);
                            if (btn) {
                                btn.click();
                                document.querySelector('.aj-tabs-bar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                            }
                        }

                        document.querySelectorAll('.aj-tab').forEach(tab => {
                            tab.addEventListener('click', () => {
                                const target = tab.dataset.tab;
                                document.querySelectorAll('.aj-tab').forEach(t => t.classList.remove('active'));
                                document.querySelectorAll('.aj-tab-panel').forEach(p => p.classList.remove('active'));
                                tab.classList.add('active');
                                document.getElementById(target).classList.add('active');
                            });
                        });

                        // Image preview
                        function ajPreview(input, previewId) {
                            if (input.files && input.files[0]) {
                                const reader = new FileReader();
                                reader.onload = e => {
                                    document.getElementById(previewId).src = e.target.result;
                                };
                                reader.readAsDataURL(input.files[0]);
                            }
                        }

                        // Ticker live preview
                        ['1', '2', '3'].forEach(n => {
                            const inp = document.querySelector(`[name="ticker_text${n}"]`);
                            const prev = document.getElementById('td' + n);
                            if (inp && prev) {
                                inp.addEventListener('input', () => { prev.textContent = inp.value; });
                            }
                        });

                        // Activate tab from URL hash
                        const hash = window.location.hash;
                        if (hash) {
                            const target = hash.replace('#', '');
                            const tabBtn = document.querySelector(`[data-tab="${target}"]`);
                            if (tabBtn) tabBtn.click();
                        }

                        // Keep backward compat for old toggleEditor calls (not used in new design)
                        function previewImage(input, id) { ajPreview(input, id); }
                    </script>

