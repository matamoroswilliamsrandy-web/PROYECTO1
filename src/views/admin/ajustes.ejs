<%- include('../partials/admin-header', { path: '/panel-director/ajustes' }) %>

    <!-- ── PAGE HEADER ── -->
    <div class="adm-page-header">
        <div class="adm-page-header-left">
            <div class="adm-page-icon adm-page-icon--red">
                <i class="fas fa-sliders-h"></i>
            </div>
            <div>
                <h1 class="adm-page-title">Ajustes del Sitio</h1>
                <p class="adm-page-sub">Controla el contenido visual de todas las páginas institucionales</p>
            </div>
        </div>
        <div class="adm-page-header-actions">
            <a href="/" target="_blank" class="aj-preview-btn">
                <i class="fas fa-eye"></i> Vista Previa
            </a>
        </div>
    </div>

    <!-- ── ALERTS ── -->
    <% if (success) { %>
        <div class="aj-alert aj-alert--success">
            <i class="fas fa-check-circle"></i>
            <span>
                <%= success %>
            </span>
        </div>
        <% } %>
            <% if (error) { %>
                <div class="aj-alert aj-alert--error">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>
                        <%= error %>
                    </span>
                </div>
                <% } %>

                    <!-- ── TAB NAVIGATION ── -->
                    <div class="aj-tabs-bar">
                        <button class="aj-tab active" data-tab="tab-stats">
                            <i class="fas fa-chart-bar"></i>
                            <span>Estadísticas</span>
                        </button>
                        <button class="aj-tab" data-tab="tab-ticker">
                            <i class="fas fa-bullhorn"></i>
                            <span>Anuncios</span>
                        </button>
                        <button class="aj-tab" data-tab="tab-propuesta">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Prop. Educativa</span>
                        </button>
                        <button class="aj-tab" data-tab="tab-mision">
                            <i class="fas fa-bullseye"></i>
                            <span>Misión y Visión</span>
                        </button>
                        <button class="aj-tab" data-tab="tab-historia">
                            <i class="fas fa-landmark"></i>
                            <span>Historia</span>
                        </button>
                    </div>



                    <!-- ════════════════════════════════════════════
     TAB 2: ESTADÍSTICAS
═════════════════════════════════════════════ -->
                    <div id="tab-stats" class="aj-tab-panel active">
                        <form action="/panel-director/ajustes/guardar" method="POST">

                            <div class="aj-section-header">
                                <div class="aj-section-icon" style="background:#fef2f2; color:#c0392b;">
                                    <i class="fas fa-chart-bar"></i>
                                </div>
                                <div>
                                    <h2>Estadísticas Institucionales</h2>
                                    <p>Contadores que aparecen en la sección de impacto de la página de inicio</p>
                                </div>
                            </div>

                            <div class="aj-stats-grid">
                                <div class="aj-stat-card">
                                    <div class="aj-stat-icon" style="background:#fef2f2; color:#c0392b;">
                                        <i class="fas fa-user-graduate"></i>
                                    </div>
                                    <label class="aj-label">Estudiantes</label>
                                    <input type="number" name="stats_estudiantes" class="aj-input aj-stat-input"
                                        value="<%= ajustes.stats_estudiantes %>">
                                </div>

                                <div class="aj-stat-card">
                                    <div class="aj-stat-icon" style="background:#fee2e2; color:#dc2626;">
                                        <i class="fas fa-chalkboard-teacher"></i>
                                    </div>
                                    <label class="aj-label">Docentes</label>
                                    <input type="number" name="stats_docentes" class="aj-input aj-stat-input"
                                        value="<%= ajustes.stats_docentes %>">
                                </div>

                                <div class="aj-stat-card">
                                    <div class="aj-stat-icon" style="background:#fef2f2; color:#c0392b;">
                                        <i class="fas fa-calendar-alt"></i>
                                    </div>
                                    <label class="aj-label">Años de Trayectoria</label>
                                    <input type="number" name="stats_años" class="aj-input aj-stat-input"
                                        value="<%= ajustes.stats_años %>">
                                </div>

                                <div class="aj-stat-card">
                                    <div class="aj-stat-icon" style="background:#fef2f2; color:#c0392b;">
                                        <i class="fas fa-trophy"></i>
                                    </div>
                                    <label class="aj-label">Premios Ganados</label>
                                    <input type="number" name="stats_premios" class="aj-input aj-stat-input"
                                        value="<%= ajustes.stats_premios %>">
                                </div>
                            </div>

                            <div class="aj-form-footer">
                                <button type="submit" class="aj-btn aj-btn--dark">
                                    <i class="fas fa-save"></i> Guardar Estadísticas
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- ════════════════════════════════════════════
     TAB 3: CINTA DE ANUNCIOS
═════════════════════════════════════════════ -->
                    <div id="tab-ticker" class="aj-tab-panel">
                        <form action="/panel-director/ajustes/guardar" method="POST">

                            <div class="aj-section-header">
                                <div class="aj-section-icon" style="background:#fef2f2; color:#c0392b;">
                                    <i class="fas fa-bullhorn"></i>
                                </div>
                                <div>
                                    <h2>Cinta de Anuncios</h2>
                                    <p>Los 3 mensajes que se desplazan en la barra roja de la parte superior del inicio
                                    </p>
                                </div>
                            </div>

                            <div class="aj-ticker-list">
                                <% [1,2,3].forEach(n=> { %>
                                    <div class="aj-ticker-row">
                                        <div class="aj-ticker-num">
                                            <%= n %>
                                        </div>
                                        <div class="aj-field" style="flex:1;">
                                            <label class="aj-label"><i class="fas fa-comment-dots"></i> Mensaje <%= n %>
                                            </label>
                                            <input type="text" name="ticker_text<%= n %>" class="aj-input"
                                                value="<%= ajustes['ticker_text' + n] %>"
                                                placeholder="Ej: ¡Matrículas Abiertas 2026!">
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <div class="aj-ticker-preview">
                                <span class="aj-ticker-preview-label"><i class="fas fa-eye"></i> Vista previa en tiempo
                                    real:</span>
                                <div class="aj-ticker-demo">
                                    <span id="td1">
                                        <%= ajustes.ticker_text1 %>
                                    </span>
                                    <span>·</span>
                                    <span id="td2">
                                        <%= ajustes.ticker_text2 %>
                                    </span>
                                    <span>·</span>
                                    <span id="td3">
                                        <%= ajustes.ticker_text3 %>
                                    </span>
                                </div>
                            </div>

                            <div class="aj-form-footer">
                                <button type="submit" class="aj-btn aj-btn--primary">
                                    <i class="fas fa-save"></i> Guardar Anuncios
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- ════════════════════════════════════════════
     TAB 4: PROPUESTA EDUCATIVA
═════════════════════════════════════════════ -->
                    <div id="tab-propuesta" class="aj-tab-panel">
                        <form action="/panel-director/ajustes/guardar" method="POST" enctype="multipart/form-data">

                            <div class="aj-section-header">
                                <div class="aj-section-icon" style="background:#fef2f2; color:#c0392b;">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                                <div>
                                    <h2>Propuesta Educativa</h2>
                                    <p>Edita el contenido de la página y su tarjeta en la portada</p>
                                </div>
                            </div>

                            <!-- Tarjeta en Portada -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-id-card"></i> Tarjeta en Portada (Cuadro 1)
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título en Tarjeta</label>
                                        <input type="text" name="card1_titulo" class="aj-input"
                                            value="<%= ajustes.card1_titulo %>">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Texto del Botón</label>
                                        <input type="text" name="card1_btn" class="aj-input"
                                            value="<%= ajustes.card1_btn %>">
                                    </div>
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Descripción Breve</label>
                                        <textarea name="card1_desc" class="aj-input aj-textarea"
                                            rows="4"><%= ajustes.card1_desc %></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Hero -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-layer-group"></i> Sección Hero (portada)
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título Hero</label>
                                        <input type="text" name="pe_hero_title" class="aj-input"
                                            value="<%= ajustes.pe_hero_title %>" placeholder="Propuesta Educativa">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Subtítulo Hero</label>
                                        <input type="text" name="pe_hero_sub" class="aj-input"
                                            value="<%= ajustes.pe_hero_sub %>" placeholder="Un modelo pedagógico...">
                                    </div>
                                </div>
                            </div>

                            <!-- Sección Principal -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-align-left"></i> Sección Principal</div>
                                <div class="aj-two-col aj-two-col--img">
                                    <div>
                                        <div class="aj-field">
                                            <label class="aj-label">Título</label>
                                            <input type="text" name="pe_seccion1_titulo" class="aj-input"
                                                value="<%= ajustes.pe_seccion1_titulo %>">
                                        </div>
                                        <div class="aj-field" style="margin-top:14px;">
                                            <label class="aj-label">Descripción</label>
                                            <textarea name="pe_seccion1_desc" class="aj-input aj-textarea"
                                                rows="5"><%= ajustes.pe_seccion1_desc %></textarea>
                                        </div>
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Imagen Principal</label>
                                        <div class="aj-uploader aj-uploader--tall">
                                            <img src="<%= ajustes.pe_img1 %>" class="aj-uploader-img" id="prev-pe1">
                                            <label class="aj-uploader-overlay" for="pe_img1">
                                                <i class="fas fa-camera"></i>
                                                <span>Cambiar imagen</span>
                                                <input type="file" id="pe_img1" name="pe_img1" accept="image/*"
                                                    onchange="ajPreview(this,'prev-pe1')">
                                            </label>
                                        </div>
                                        <p class="aj-hint">Recomendado 800×600 px</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Pilares -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-th"></i> Pilares del Modelo Educativo (4)
                                </div>
                                <div class="aj-four-col">
                                    <% [1,2,3,4].forEach(p=> { %>
                                        <div class="aj-pilar-card">
                                            <div class="aj-pilar-num">
                                                <%= p %>
                                            </div>
                                            <div class="aj-field">
                                                <label class="aj-label">Título</label>
                                                <input type="text" name="pe_pil<%= p %>_t" class="aj-input"
                                                    value="<%= ajustes['pe_pil'+p+'_t'] %>">
                                            </div>
                                            <div class="aj-field">
                                                <label class="aj-label">Descripción</label>
                                                <textarea name="pe_pil<%= p %>_d" class="aj-input aj-textarea"
                                                    rows="3"><%= ajustes['pe_pil'+p+'_d'] %></textarea>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>

                            <div class="aj-form-footer">
                                <button type="submit" class="aj-btn aj-btn--primary">
                                    <i class="fas fa-save"></i> Guardar Propuesta Educativa
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- ════════════════════════════════════════════
     TAB 5: MISIÓN Y VISIÓN
═════════════════════════════════════════════ -->
                    <div id="tab-mision" class="aj-tab-panel">
                        <form action="/panel-director/ajustes/guardar" method="POST" enctype="multipart/form-data">

                            <div class="aj-section-header">
                                <div class="aj-section-icon" style="background:#fef2f2; color:#c0392b;">
                                    <i class="fas fa-bullseye"></i>
                                </div>
                                <div>
                                    <h2>Misión y Visión</h2>
                                    <p>Edita los propósitos institucionales y su tarjeta en la portada</p>
                                </div>
                            </div>

                            <!-- Tarjeta en Portada -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-id-card"></i> Tarjeta en Portada (Cuadro 2)
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título en Tarjeta</label>
                                        <input type="text" name="card2_titulo" class="aj-input"
                                            value="<%= ajustes.card2_titulo %>">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Texto del Botón</label>
                                        <input type="text" name="card2_btn" class="aj-input"
                                            value="<%= ajustes.card2_btn %>">
                                    </div>
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Descripción Breve</label>
                                        <textarea name="card2_desc" class="aj-input aj-textarea"
                                            rows="4"><%= ajustes.card2_desc %></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Hero -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-layer-group"></i> Sección Hero (portada)
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título Hero</label>
                                        <input type="text" name="mv_hero_title" class="aj-input"
                                            value="<%= ajustes.mv_hero_title %>" placeholder="Misión y Visión">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Subtítulo Hero</label>
                                        <input type="text" name="mv_hero_sub" class="aj-input"
                                            value="<%= ajustes.mv_hero_sub %>"
                                            placeholder="Principios fundamentales...">
                                    </div>
                                </div>
                            </div>

                            <!-- Misión -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-rocket"></i> Misión
                                </div>
                                <div class="aj-two-col aj-two-col--img">
                                    <div>
                                        <div class="aj-field">
                                            <label class="aj-label">Título Misión</label>
                                            <input type="text" name="mv_mision_titulo" class="aj-input"
                                                value="<%= ajustes.mv_mision_titulo %>">
                                        </div>
                                        <div class="aj-field" style="margin-top:14px;">
                                            <label class="aj-label">Descripción Misión</label>
                                            <textarea name="mv_mision_desc" class="aj-input aj-textarea"
                                                rows="4"><%= ajustes.mv_mision_desc %></textarea>
                                        </div>
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Imagen Misión</label>
                                        <div class="aj-uploader aj-uploader--tall">
                                            <img src="<%= ajustes.mv_mision_img %>" class="aj-uploader-img"
                                                id="prev-mv-m">
                                            <label class="aj-uploader-overlay" for="mv_mision_img">
                                                <i class="fas fa-camera"></i>
                                                <span>Cambiar imagen</span>
                                                <input type="file" id="mv_mision_img" name="mv_mision_img"
                                                    accept="image/*" onchange="ajPreview(this,'prev-mv-m')">
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Visión -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-star"></i> Visión
                                </div>
                                <div class="aj-two-col aj-two-col--img">
                                    <div>
                                        <div class="aj-field">
                                            <label class="aj-label">Título Visión</label>
                                            <input type="text" name="mv_vision_titulo" class="aj-input"
                                                value="<%= ajustes.mv_vision_titulo %>">
                                        </div>
                                        <div class="aj-field" style="margin-top:14px;">
                                            <label class="aj-label">Descripción Visión</label>
                                            <textarea name="mv_vision_desc" class="aj-input aj-textarea"
                                                rows="4"><%= ajustes.mv_vision_desc %></textarea>
                                        </div>
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Imagen Visión</label>
                                        <div class="aj-uploader aj-uploader--tall">
                                            <img src="<%= ajustes.mv_vision_img %>" class="aj-uploader-img"
                                                id="prev-mv-v">
                                            <label class="aj-uploader-overlay" for="mv_vision_img">
                                                <i class="fas fa-camera"></i>
                                                <span>Cambiar imagen</span>
                                                <input type="file" id="mv_vision_img" name="mv_vision_img"
                                                    accept="image/*" onchange="ajPreview(this,'prev-mv-v')">
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="aj-form-footer">
                                <button type="submit" class="aj-btn aj-btn--primary">
                                    <i class="fas fa-save"></i> Guardar Misión y Visión
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- ════════════════════════════════════════════
     TAB 6: HISTORIA
═════════════════════════════════════════════ -->
                    <div id="tab-historia" class="aj-tab-panel">
                        <form action="/panel-director/ajustes/guardar" method="POST" enctype="multipart/form-data">

                            <div class="aj-section-header">
                                <div class="aj-section-icon" style="background:#fef2f2; color:#c0392b;">
                                    <i class="fas fa-landmark"></i>
                                </div>
                                <div>
                                    <h2>Historia Institucional</h2>
                                    <p>Edita el legado de la institución y su tarjeta en la portada</p>
                                </div>
                            </div>

                            <!-- Tarjeta en Portada -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-id-card"></i> Tarjeta en Portada (Cuadro 3)
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título en Tarjeta</label>
                                        <input type="text" name="card3_titulo" class="aj-input"
                                            value="<%= ajustes.card3_titulo %>">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Texto del Botón</label>
                                        <input type="text" name="card3_btn" class="aj-input"
                                            value="<%= ajustes.card3_btn %>">
                                    </div>
                                </div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Descripción Breve</label>
                                        <textarea name="card3_desc" class="aj-input aj-textarea"
                                            rows="4"><%= ajustes.card3_desc %></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Hero + Sección 1 -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-layer-group"></i> Sección Principal</div>
                                <div class="aj-two-col">
                                    <div class="aj-field">
                                        <label class="aj-label">Título Hero</label>
                                        <input type="text" name="hist_hero_title" class="aj-input"
                                            value="<%= ajustes.hist_hero_title %>" placeholder="Nuestra Historia">
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Subtítulo del Hero</label>
                                        <input type="text" name="hist_hero_sub" class="aj-input"
                                            value="<%= ajustes.hist_hero_sub %>">
                                    </div>
                                </div>
                                <div class="aj-two-col aj-two-col--img">
                                    <div>
                                        <div class="aj-field">
                                            <label class="aj-label">Título Sección 1</label>
                                            <input type="text" name="hist_seccion1_titulo" class="aj-input"
                                                value="<%= ajustes.hist_seccion1_titulo %>">
                                        </div>
                                        <div class="aj-field" style="margin-top:14px;">
                                            <label class="aj-label">Descripción Sección 1</label>
                                            <textarea name="hist_seccion1_desc" class="aj-input aj-textarea"
                                                rows="5"><%= ajustes.hist_seccion1_desc %></textarea>
                                        </div>
                                    </div>
                                    <div class="aj-field">
                                        <label class="aj-label">Imagen Historia</label>
                                        <div class="aj-uploader aj-uploader--tall">
                                            <img src="<%= ajustes.hist_img1 %>" class="aj-uploader-img" id="prev-hist1">
                                            <label class="aj-uploader-overlay" for="hist_img1">
                                                <i class="fas fa-camera"></i>
                                                <span>Cambiar imagen</span>
                                                <input type="file" id="hist_img1" name="hist_img1" accept="image/*"
                                                    onchange="ajPreview(this,'prev-hist1')">
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Línea de Tiempo -->
                            <div class="aj-group">
                                <div class="aj-group-title"><i class="fas fa-stream"></i> Línea de Tiempo — 3 Hitos
                                </div>
                                <div class="aj-three-col">
                                    <% [1,2,3].forEach(n=> { %>
                                        <div class="aj-timeline-card">
                                            <div class="aj-timeline-dot">
                                                <%= n %>
                                            </div>
                                            <div class="aj-field">
                                                <label class="aj-label">Año</label>
                                                <input type="text" name="hist_t<%= n %>_anio"
                                                    class="aj-input aj-year-input"
                                                    value="<%= ajustes['hist_t'+n+'_anio'] %>" placeholder="Ej: 1985">
                                            </div>
                                            <div class="aj-field">
                                                <label class="aj-label">Título del Hito</label>
                                                <input type="text" name="hist_t<%= n %>_titulo" class="aj-input"
                                                    value="<%= ajustes['hist_t'+n+'_titulo'] %>">
                                            </div>
                                            <div class="aj-field">
                                                <label class="aj-label">Descripción</label>
                                                <textarea name="hist_t<%= n %>_desc" class="aj-input aj-textarea"
                                                    rows="3"><%= ajustes['hist_t'+n+'_desc'] %></textarea>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>

                            <div class="aj-form-footer">
                                <button type="submit" class="aj-btn aj-btn--primary">
                                    <i class="fas fa-save"></i> Guardar Historia
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- ══ STYLES ══════════════════════════════════════════════════════════ -->
                    <style>
                        /* ── Variables ── */
                        :root {
                            --aj-red: #c0392b;
                            --aj-navy: #0f172a;
                            --aj-slate: #475569;
                            --aj-border: #e2e8f0;
                            --aj-bg: #f8fafc;
                            --aj-card: #ffffff;
                            --aj-radius: 20px;
