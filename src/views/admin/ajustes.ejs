                        }

                        .aj-alert--success {
                            background: #f0fdf4;
                            border: 1px solid #bbf7d0;
                            color: #15803d;
                        }

                        .aj-alert--error {
                            background: #fef2f2;
                            border: 1px solid #fecaca;
                            color: #dc2626;
                        }

                        .aj-alert i {
                            font-size: 1.2rem;
                        }

                        @keyframes ajSlideDown {
                            from {
                                opacity: 0;
                                transform: translateY(-12px);
                            }

                            to {
                                opacity: 1;
                                transform: translateY(0);
                            }
                        }

                        /* ── Preview button ── */
                        .aj-preview-btn {
                            display: inline-flex;
                            align-items: center;
                            gap: 8px;
                            background: #f1f5f9;
