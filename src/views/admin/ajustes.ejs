                            --aj-shadow-hover: 0 12px 40px rgba(15, 23, 42, 0.10);
                            --aj-transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                        }

                        /* ── Alerts ── */
                        .aj-alert {
                            display: flex;
                            align-items: center;
                            gap: 14px;
                            padding: 16px 22px;
                            border-radius: 14px;
                            font-weight: 700;
                            font-size: 0.95rem;
                            margin-bottom: 24px;
