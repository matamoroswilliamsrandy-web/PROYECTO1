<%- include('../partials/admin-header', { path: '/panel-director/autoridades' }) %>

    <!-- ═══════════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════════════ -->
    <div class="adm-page-header">
        <div class="adm-page-header-left">
            <div class="adm-page-icon adm-page-icon--red">
                <i class="fas fa-users-cog"></i>
            </div>
            <div>
                <h1 class="adm-page-title">Gestión de Autoridades</h1>
                <p class="adm-page-sub">
                    <%= autoridades.length %> autoridad<%= autoridades.length !==1 ? 'es' : '' %> registrada<%=
                                autoridades.length !==1 ? 's' : '' %>
                </p>
            </div>
        </div>
        <div class="adm-page-header-actions">
            <a href="/" target="_blank" class="adm-header-link">
                <i class="fas fa-globe"></i> <span>Ver Sitio</span>
            </a>
            <button id="btn-toggle-form" class="adm-btn-new" onclick="toggleForm()">
                <i class="fas fa-plus" id="btn-icon"></i>
                <span id="btn-label">Nueva Autoridad</span>
            </button>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
     MAIN LAYOUT: SIDE PANEL + TABLE
════════════════════════════════════════════════ -->
    <div class="adm-noticias-layout" id="noticias-layout">

        <!-- ── FORM SIDE PANEL ──────────────────────── -->
        <aside class="adm-side-panel" id="side-panel" aria-hidden="true">
            <div class="adm-side-panel-inner">

                <div class="adm-drawer-header">
                    <div class="adm-drawer-title-group">
                        <div class="adm-form-panel-icon">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div>
                            <h3>Nueva Autoridad</h3>
                            <p>Completa los campos y guarda</p>
                        </div>
                    </div>
                    <button class="adm-drawer-close" onclick="toggleForm()" title="Cerrar">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <form action="/panel-director/autoridades/crear" method="POST" enctype="multipart/form-data"
                    class="adm-drawer-form">

                    <div class="adm-field">
                        <label class="adm-label" for="aut-nombre">
                            <i class="fas fa-user"></i> Nombre Completo
                        </label>
                        <input id="aut-nombre" type="text" name="nombre" class="adm-input" required
                            placeholder="Ej. Juan Pérez…">
                    </div>

                    <div class="adm-field">
                        <label class="adm-label" for="aut-cargo">
                            <i class="fas fa-briefcase"></i> Cargo
                        </label>
                        <input id="aut-cargo" type="text" name="cargo" class="adm-input" required
                            placeholder="Ej. Director General">
                    </div>

                    <div class="adm-field">
                        <label class="adm-label" for="aut-orden">
                            <i class="fas fa-sort-numeric-up"></i> Orden de Aparición
                        </label>
                        <input id="aut-orden" type="number" name="orden" class="adm-input" value="0" min="0"
                            placeholder="Menor número aparece primero">
                        <span style="font-size:0.73rem; color:#94a3b8; margin-top:2px;">Menor número = mayor
                            prioridad</span>
                    </div>

                    <div class="adm-field">
                        <label class="adm-label" for="aut-imagen">
                            <i class="fas fa-camera"></i> Fotografía
                        </label>
                        <label class="adm-file-label" for="aut-imagen">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span id="aut-file-name">Seleccionar fotografía…</span>
                            <input id="aut-imagen" type="file" name="imagen" accept="image/*"
                                onchange="document.getElementById('aut-file-name').textContent = this.files[0]?.name || 'Seleccionar fotografía…'">
                        </label>
                    </div>

                    <div class="adm-side-form-actions">
                        <button type="submit" class="adm-btn-submit">
                            <i class="fas fa-save"></i> Guardar Autoridad
                        </button>
                        <button type="button" class="adm-btn-cancel" onclick="toggleForm()">
                            Cancelar
                        </button>
                    </div>

                </form>
            </div>
        </aside>

        <!-- ── TABLE PANEL ──────────────────────────── -->
        <section class="adm-table-panel">

            <!-- Search bar -->
            <div class="adm-table-panel-header">
                <h3><i class="fas fa-users"></i> Autoridades Actuales</h3>
                <div class="adm-search-wrap">
                    <i class="fas fa-search adm-search-icon"></i>
                    <input type="text" id="aut-search" class="adm-search-input" placeholder="Buscar autoridad…"
                        oninput="filterAut(this.value)">
                    <button class="adm-search-clear" id="aut-clear-search" onclick="clearAutSearch()" title="Limpiar">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <span class="adm-count-badge" id="aut-visible-count">
                    <%= autoridades.length %>
                </span>
            </div>

            <% if (autoridades.length===0) { %>
                <div class="adm-empty-state">
                    <div class="adm-empty-icon"><i class="fas fa-users-cog"></i></div>
                    <p>No hay autoridades registradas todavía.</p>
                    <span>Haz clic en <strong>Nueva Autoridad</strong> para agregar la primera.</span>
                </div>
                <% } else { %>

                    <!-- Desktop table -->
                    <div class="adm-tbl-wrap">
                        <table class="adm-tbl">
                            <thead>
                                <tr>
                                    <th style="width:55px; text-align:center">Orden</th>
                                    <th style="width:65px">Foto</th>
                                    <th>Nombre</th>
                                    <th style="width:200px">Cargo</th>
                                    <th style="width:90px; text-align:center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="aut-tbody">
                                <% autoridades.forEach(autoridad=> { %>
                                    <tr class="adm-tbl-row"
                                        data-name="<%= autoridad.nombre.toLowerCase() %> <%= autoridad.cargo.toLowerCase() %>">
                                        <td style="text-align:center">
                                            <span class="adm-orden-badge">
                                                <%= autoridad.orden %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (autoridad.imagen) { %>
                                                <img src="<%= autoridad.imagen %>" alt="<%= autoridad.nombre %>"
                                                    class="adm-avatar-thumb">
                                                <% } else { %>
                                                    <div class="adm-avatar-thumb adm-avatar-thumb--empty">
                                                        <i class="fas fa-user"></i>
                                                    </div>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <span class="adm-tbl-title" style="-webkit-line-clamp:1; line-clamp:1">
                                                <%= autoridad.nombre %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="adm-meta-item">
                                                <i class="fas fa-briefcase"></i>
                                                <%= autoridad.cargo %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="adm-tbl-actions">
                                                <a href="/panel-director/autoridades/editar/<%= autoridad.id %>"
                                                    class="adm-action-btn adm-action-btn--edit" title="Editar">
                                                    <i class="fas fa-pen"></i>
                                                </a>
                                                <form action="/panel-director/autoridades/eliminar/<%= autoridad.id %>"
                                                    method="POST"
                                                    onsubmit="return confirm('¿Eliminar esta autoridad?');">
                                                    <button type="submit" class="adm-action-btn adm-action-btn--delete"
                                                        title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>

                        <div class="adm-no-results" id="aut-no-results" style="display:none;">
                            <i class="fas fa-search"></i>
                            <p>No se encontraron autoridades que coincidan.</p>
                        </div>
                    </div>

                    <!-- Mobile cards -->
                    <div class="adm-mobile-list" id="aut-mobile-list">
                        <% autoridades.forEach(autoridad=> { %>
                            <div class="adm-news-item"
                                data-name="<%= autoridad.nombre.toLowerCase() %> <%= autoridad.cargo.toLowerCase() %>">
                                <div class="adm-news-thumb" style="border-radius:50%">
                                    <% if (autoridad.imagen) { %>
                                        <img src="<%= autoridad.imagen %>" alt="<%= autoridad.nombre %>">
                                        <% } else { %>
                                            <div class="adm-news-thumb-placeholder"><i class="fas fa-user"></i></div>
                                            <% } %>
                                </div>
                                <div class="adm-news-body">
                                    <p class="adm-news-title">
                                        <%= autoridad.nombre %>
                                    </p>
                                    <div class="adm-news-meta">
                                        <span class="adm-meta-item">
                                            <i class="fas fa-briefcase"></i>
                                            <%= autoridad.cargo %>
                                        </span>
                                        <span class="adm-orden-badge" style="font-size:0.7rem">Orden: <%=
                                                autoridad.orden %></span>
                                    </div>
                                </div>
                                <div class="adm-news-actions">
                                    <a href="/panel-director/autoridades/editar/<%= autoridad.id %>"
                                        class="adm-action-btn adm-action-btn--edit"><i class="fas fa-pen"></i></a>
                                    <form action="/panel-director/autoridades/eliminar/<%= autoridad.id %>"
                                        method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar?');">
                                        <button type="submit" class="adm-action-btn adm-action-btn--delete"><i
                                                class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <% } %>
        </section>

    </div>

    <!-- ── SCRIPTS ────────────────────────────────── -->
    <script>
        function toggleForm() {
            const layout = document.getElementById('noticias-layout');
            const panel = document.getElementById('side-panel');
            const icon = document.getElementById('btn-icon');
            const label = document.getElementById('btn-label');
            const isOpen = layout.classList.toggle('panel-open');

            panel.setAttribute('aria-hidden', String(!isOpen));
            icon.className = isOpen ? 'fas fa-times' : 'fas fa-plus';
            label.textContent = isOpen ? 'Cerrar' : 'Nueva Autoridad';

            if (isOpen) {
                setTimeout(() => document.getElementById('aut-nombre')?.focus(), 350);
            }
        }

        function filterAut(query) {
            const q = query.toLowerCase().trim();
            const rows = document.querySelectorAll('#aut-tbody .adm-tbl-row');
            const cards = document.querySelectorAll('#aut-mobile-list .adm-news-item');
            const noRes = document.getElementById('aut-no-results');
            const badge = document.getElementById('aut-visible-count');
            const clearBtn = document.getElementById('aut-clear-search');

            let visible = 0;
            rows.forEach(r => {
                const match = !q || r.dataset.name.includes(q);
                r.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            cards.forEach(c => {
                c.style.display = (!q || c.dataset.name.includes(q)) ? '' : 'none';
            });

            badge.textContent = visible;
            noRes.style.display = (visible === 0 && q) ? 'flex' : 'none';
            clearBtn.style.opacity = q ? '1' : '0';
            clearBtn.style.pointerEvents = q ? 'auto' : 'none';
        }

        function clearAutSearch() {
            const input = document.getElementById('aut-search');
            input.value = '';
            filterAut('');
            input.focus();
        }
    </script>

    <%- include('../partials/admin-footer') %>