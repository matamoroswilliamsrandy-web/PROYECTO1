<%- include('../partials/header') %>

    <!-- Custom Style for this page -->
    <link rel="stylesheet" href="/css/pages/detalle.css">

    <div class="detalle-page-wrapper">

        <!-- Header minimalista sin imagen gigante -->
        <header class="detalle-hero-clean">
            <div class="container">
                <div class="detalle-badge-wrap">
                    <span class="detalle-tag evento">
                        <i class="far fa-calendar-check"></i> Evento Institucional
                    </span>
                </div>
                <h1 class="detalle-title">
                    <%= evento.titulo %>
                </h1>
                <div class="detalle-meta">
                    <span>
                        <i class="far fa-calendar-alt"></i>
                        Fecha: <%= new Date(evento.fecha_evento).toLocaleDateString('es-ES', { day: 'numeric' ,
                            month: 'long' , year: 'numeric' }) %>
                    </span>
                    <% if(evento.hora_evento) { %>
                        <span>
                            <i class="far fa-clock"></i>
                            Hora: <%= evento.hora_evento %>
                        </span>
                        <% } %>
                            <% if(evento.lugar) { %>
                                <span>
                                    <i class="fas fa-map-marker-alt"></i>
                                    <%= evento.lugar %>
                                </span>
                                <% } %>
                </div>
            </div>
        </header>

        <section class="detalle-container">
            <article class="detalle-main-card">
                <% if(evento.imagen) { %>
                    <!-- Contenedor de Imagen con Efecto Blur y Slider -->
                    <div class="detalle-img-framing">
                        <% if(evento.imagen2 || evento.imagen3) { %>
                            <!-- Slider si hay múltiples imágenes -->
                            <div class="detalle-slider-container">
                                <div class="detalle-slides" id="detail-slides">
                                    <div class="detalle-slide">
                                        <div class="detalle-img-bg-blur"><img src="<%= evento.imagen %>" alt=""></div>
                                        <img src="<%= evento.imagen %>" alt="<%= evento.titulo %>">
                                    </div>
                                    <% if(evento.imagen2) { %>
                                        <div class="detalle-slide">
                                            <div class="detalle-img-bg-blur"><img src="<%= evento.imagen2 %>" alt="">
                                            </div>
                                            <img src="<%= evento.imagen2 %>" alt="<%= evento.titulo %>">
                                        </div>
                                        <% } %>
                                            <% if(evento.imagen3) { %>
                                                <div class="detalle-slide">
                                                    <div class="detalle-img-bg-blur"><img src="<%= evento.imagen3 %>"
                                                            alt=""></div>
                                                    <img src="<%= evento.imagen3 %>" alt="<%= evento.titulo %>">
                                                </div>
                                                <% } %>
                                </div>

                                <div class="slider-nav">
                                    <div class="slider-btn prev" onclick="moveSlider(-1)"><i
                                            class="fas fa-chevron-left"></i></div>
                                    <div class="slider-btn next" onclick="moveSlider(1)"><i
                                            class="fas fa-chevron-right"></i></div>
                                </div>

                                <div class="slider-dots">
                                    <div class="slider-dot active" onclick="setSlide(0)"></div>
                                    <% if(evento.imagen2) { %>
                                        <div class="slider-dot" onclick="setSlide(1)"></div>
                                        <% } %>
                                            <% if(evento.imagen3) { %>
                                                <div class="slider-dot"
                                                    onclick="setSlide(<%= evento.imagen2 ? 2 : 1 %>)"></div>
                                                <% } %>
                                </div>
                            </div>
                            <% } else { %>
                                <!-- Imagen única con Blur Background -->
                                <div class="detalle-img-bg-blur"><img src="<%= evento.imagen %>" alt=""></div>
                                <img src="<%= evento.imagen %>" alt="<%= evento.titulo %>" class="detalle-main-image">
                                <% } %>
                    </div>
                    <% } %>

                        <div class="detalle-content-grid">
                            <div class="detalle-text">
                                <h3 class="detalle-summary-title">
                                    <i class="fas fa-microchip"></i> Detalles del Evento
                                </h3>
                                <div class="detalle-body">
                                    <%- (evento.contenido || evento.descripcion).replace(/\n/g, '<br>' ) %>
                                </div>

                                <div class="event-card-premium">
                                    <div class="event-card-premium-header">
                                        <div class="event-card-premium-icon">
                                            <i class="fas fa-ticket-alt"></i>
                                        </div>
                                        <div>
                                            <h4>Asistencia</h4>
                                            <p>Evento Institucional</p>
                                        </div>
                                    </div>
                                    <p class="event-card-info">¡Te esperamos! Confirma tu asistencia directamente vía
                                        WhatsApp.</p>
                                    <a href="https://wa.me/51987654321?text=Hola! Quisiera confirmar mi asistencia al evento: <%= evento.titulo %>"
                                        target="_blank" class="btn-sidebar-primary-premium">
                                        <i class="fab fa-whatsapp"></i> Confirmar Asistencia
                                    </a>
                                </div>
                            </div>

                            <!-- Panel lateral de acciones -->
                            <aside class="detalle-sidebar">
                                <div class="share-box">
                                    <h4><i class="fas fa-share-alt"></i> Compartir</h4>
                                    <div class="share-buttons-col">
                                        <a href="#" class="share-btn fb" onclick="shareOnFacebook(event)">
                                            <i class="fab fa-facebook-f"></i> Facebook
                                        </a>
                                        <a href="#" class="share-btn tw" onclick="shareOnTwitter(event)">
                                            <i class="fab fa-twitter-x"></i> Twitter
                                        </a>
                                        <a href="#" class="share-btn wa" onclick="shareOnWhatsApp(event)">
                                            <i class="fab fa-whatsapp"></i> WhatsApp
                                        </a>
                                        <a href="#" class="share-btn copy" onclick="copyPageLink(event)">
                                            <i class="fas fa-link"></i> Copiar Enlace
                                        </a>
                                    </div>
                                </div>

                                <script>
                                    // Slider Navigation
                                    let currentSlide = 0;
                                    const totalSlides = document.querySelectorAll('.detalle-slide').length;

                                    function updateSlider() {
                                        const slides = document.getElementById('detail-slides');
                                        const dots = document.querySelectorAll('.slider-dot');
                                        if (slides) {
                                            slides.style.transform = `translateX(-${currentSlide * 100}%)`;
                                            dots.forEach((dot, idx) => {
                                                dot.classList.toggle('active', idx === currentSlide);
                                            });
                                        }
                                    }

                                    function moveSlider(dir) {
                                        currentSlide = (currentSlide + dir + totalSlides) % totalSlides;
                                        updateSlider();
                                    }

                                    function setSlide(idx) {
                                        currentSlide = idx;
                                        updateSlider();
                                    }

                                    function shareOnFacebook(e) {
                                        e.preventDefault();
                                        const url = window.location.href;
                                        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank', 'width=600,height=400');
                                    }
                                    function shareOnTwitter(e) {
                                        e.preventDefault();
                                        const url = window.location.href;
                                        const text = "<%= evento.titulo %>";
                                        window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`, '_blank', 'width=600,height=400');
                                    }
                                    function shareOnWhatsApp(e) {
                                        e.preventDefault();
                                        const url = window.location.href;
                                        const text = "<%= evento.titulo %>";
                                        window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(text + ' ' + url)}`, '_blank');
                                    }
                                    function copyPageLink(e) {
                                        e.preventDefault();
                                        const url = window.location.href;
                                        navigator.clipboard.writeText(url).then(() => {
                                            const btn = e.currentTarget;
                                            const originalText = btn.innerHTML;
                                            btn.innerHTML = '<i class="fas fa-check"></i> ¡Copiado!';
                                            btn.classList.add('success');
                                            setTimeout(() => {
                                                btn.innerHTML = originalText;
                                                btn.classList.remove('success');
                                            }, 2000);
                                        });
                                    }
                                </script>
                                <a href="/eventos" class="btn-back-sidebar">
                                    <i class="fas fa-arrow-left"></i> Volver a Eventos
                                </a>
                            </aside>
                        </div>
            </article>
        </section>

    </div>

    <%- include('../partials/footer') %>